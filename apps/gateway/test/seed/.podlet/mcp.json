{
  "mcpServers": {
    "ddg-search": {
      "command": "uvx",
        "args": ["duckduckgo-mcp-server"]
    },
    "context7": {
      "command": "npx",
        "args": ["-y", "@upstash/context7-mcp"]
    },
    "memory": {
      "command": "docker",
      "args": ["run", "-i", "-v", "claude-memory:/app/dist", "--rm", "mcp/memory"]
    }
  }
}


